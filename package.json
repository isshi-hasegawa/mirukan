    "@supabase/supabase-js": "^2.100.1",
    "@tanstack/react-query": "^5.97.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "nuqs": "^2.8.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.1.1",
    "simple-icons": "^16.13.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
