{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "supabase/functions/*/index.ts",
    "supabase/functions/**/*_test.ts",
    "playwright.integration.config.ts",
    "e2e/global-setup.ts",
    "e2e/mock-supabase-server.ts"
  ],
  "project": [
    "src/**/*.{ts,tsx}",
    "supabase/functions/**/*.ts",
    "e2e/**/*.ts",
    "*.config.{js,ts}",
    "!**/dist/**",
    "!.claude/worktrees/**"
  ],
  "ignoreFiles": ["postcss.config.js"],
  "ignoreDependencies": [
    "@tailwindcss/postcss",
    "autoprefixer",
    "jsr",
    "npm",
    "shadcn",
    "tailwindcss",
    "tw-animate-css"
  ]
}
